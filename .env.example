# Frontend (use /api in dev so Vite proxies to the API; leave unset in production builds)
# VITE_API_URL=/api
VITE_WS_URL=ws://localhost:8000/ws
VITE_DEMO_MODE=true

# Backend — SQLite works out of the box for native .\start.ps1 (no Docker)
DATABASE_URL=sqlite+aiosqlite:///./purrscription.db
# PostgreSQL (used automatically with .\start.ps1 -Docker):
# DATABASE_URL=postgresql+asyncpg://purrscription:purrscription@localhost:5432/purrscription
REDIS_URL=redis://localhost:6379
ENVIRONMENT=development
PURRSCRIPTION_DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=dev-secret-change-in-production

# ASR (faster-whisper)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# AI
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Security
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Features
FEATURE_QUALITY_FIREWALL=true
FEATURE_DEMO_MODE=true
DEMO_USER_PASSWORD=demo123
